{
  "name": "@pixellabs/cli",
  "version": "0.1.0",
  "description": "Command-line interface for PixelLabs AI NFT generation",
  "type": "module",
  "bin": {
    "pixellabs": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pixellabs/core": "workspace:*",
    "@pixellabs/sdk": "workspace:*",
    "commander": "^11.1.0",
    "inquirer": "^9.2.0",
    "ora": "^7.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}